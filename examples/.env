# ======================
# === Syncthing Settings ===
# ======================
API_KEY=changeme                 # Syncthing API key
HOST=syncthing.local             # Syncthing host/IP
PORT=8384                        # Syncthing WebUI port
API_TIMEOUT=15                   # Timeout for API requests (seconds)

# ======================
# === Cleanup & Hardlink Settings ===
# ======================
CLEANUP_AFTER_HOURS=24           # Delete files older than this
CLEANUP_INTERVAL_MINUTES=360     # How often cleanup runs (minutes)
CLEANUP_BATCH_SIZE=100           # Number of files to delete per batch
KEEP_RECENT_FILES=10             # Always keep this many recent files
GRACE_PERIOD_MINUTES=15          # Minimum age before file can be deleted or linked
LOG_GRACE_PERIOD_SKIPS=True      # Log files skipped due to grace period
OWNER_UID=1000                   # UID for hardlinked files
OWNER_GID=1000                   # GID for hardlinked files

# ======================
# === Ignore Files/Patterns ===
# ======================
IGNORE_FILES=.stfolder
IGNORE_PATTERNS=.syncthing.,.tmp,.nfo,sample,.txt,.jpg,.jpeg,.png,.sfv,.md5,.crc

# ======================
# === App Folder Instances ===
# Format for multiple instances:
# <APP>_<INDEX>_FOLDER_LABEL
# <APP>_<INDEX>_SYNCFOLDER_PATH
# <APP>_<INDEX>_SYNCMOVER_PATH
# ======================

# Example Radarr instances
RADARR_0_FOLDER_LABEL=Movies
RADARR_0_SYNCFOLDER_PATH=/sync/radarr
RADARR_0_SYNCMOVER_PATH=/media/radarr

RADARR_1_FOLDER_LABEL=Movies4K
RADARR_1_SYNCFOLDER_PATH=/sync/radarr_4k
RADARR_1_SYNCMOVER_PATH=/media/radarr_4k

# Example Sonarr instance
SONARR_0_FOLDER_LABEL=TVShows
SONARR_0_SYNCFOLDER_PATH=/sync/sonarr
SONARR_0_SYNCMOVER_PATH=/media/sonarr

# Example Lidarr instance
LIDARR_0_FOLDER_LABEL=Music
LIDARR_0_SYNCFOLDER_PATH=/sync/lidarr
LIDARR_0_SYNCMOVER_PATH=/media/lidarr

# You can add any other app with any name, just follow the same naming pattern:
# APPNAME_INDEX_FOLDER_LABEL
# APPNAME_INDEX_SYNCFOLDER_PATH
# APPNAME_INDEX_SYNCMOVER_PATH
