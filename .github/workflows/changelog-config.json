{
  "categories": [
    {
      "title": "✨ Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "🐛 Fixes",
      "labels": ["bug", "fix"]
    },
    {
      "title": "🛠 Maintenance",
      "labels": ["chore", "refactor", "docs", "dependencies"]
    }
  ],
  "sort": "ASC",
  "template": "## Changes\n\n${{CHANGELOG}}",
  "pr_template": "- ${{TITLE}} (#${{NUMBER}}) by @${{AUTHOR}}",
  "empty_template": "No changes in this release."
}